---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — wangtsaiti" description="Page not found.">
  <section class="section wrap contact" style="min-height: 60vh; display: grid; place-content: center; text-align: center;">
    <div>
      <p class="eyebrow">404</p>
      <h1 class="contact-title">This page wandered off.</h1>
      <p class="contact-lede">The link may be broken, or the page has moved.</p>
      <a class="btn btn-primary" href="/" style="margin-top: 2rem;">Back home</a>
    </div>
  </section>
</BaseLayout>
