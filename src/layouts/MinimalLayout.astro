---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'wangtsaiti — selected work',
  description = 'wangtsaiti (zurara) — designer at Orthogonal. Selected projects and writing.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Urbanist:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        height: 100%;
        margin: 0;
        /* fixed height — the page itself never scrolls */
        overflow: hidden;
        background: #ffffff;
        color: #0a0a0a;
        font-family: 'Urbanist', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        /* the home is drawing paper — drags draw, they never select text */
        user-select: none;
        -webkit-user-select: none;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      .skip-link {
        position: fixed;
        left: -9999px;
        top: 0;
      }
      .skip-link:focus {
        left: 12px;
        top: 12px;
        z-index: 100;
        background: #0a0a0a;
        color: #fff;
        padding: 8px 12px;
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#cards">Skip to work</a>
    <slot />
  </body>
</html>
