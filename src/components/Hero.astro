---
import site from '../content/site.json';
---

<section class="hero wrap" id="top">
  <p class="eyebrow reveal">{site.greeting}</p>
  <h1 class="hero-title reveal">
    {site.heroBefore} <em>{site.heroEmphasis}</em><br />
    {site.heroAfter}
  </h1>
  <p class="hero-lede reveal">
    I'm <strong>{site.name}</strong> — {site.introMiddle}{' '}
    <a href={site.orgUrl} target="_blank" rel="noopener">{site.orgName}</a>.
  </p>
  <div class="hero-actions reveal">
    <a class="btn btn-primary" href="#work">See selected work</a>
    <a class="btn btn-ghost" href="#contact">Get in touch</a>
  </div>
  <p class="status reveal">
    <span class="status-dot" aria-hidden="true"></span>
    {site.status}
  </p>
</section>
