---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order || b.data.year.localeCompare(a.data.year)
);

const linkFor = (entry: (typeof projects)[number]) =>
  entry.data.externalUrl ?? `/work/${entry.id}`;
const isExternal = (entry: (typeof projects)[number]) => Boolean(entry.data.externalUrl);
---

<section class="section wrap" id="work">
  <div class="section-head reveal">
    <h2 class="section-title">Selected work</h2>
    <p class="section-note">A few things I'm proud of. More on the way.</p>
  </div>

  <ul class="work-grid" data-cards>
    {
      projects.map((entry) => (
        <li class="work-card" data-card>
          <a
            class="work-card-link"
            href={linkFor(entry)}
            target={isExternal(entry) ? '_blank' : undefined}
            rel={isExternal(entry) ? 'noopener' : undefined}
          >
            <div class="work-card-media" style={`--accent-fill:${entry.data.accent}`}>
              {entry.data.cover ? (
                <img src={entry.data.cover} alt="" loading="lazy" />
              ) : (
                <span class="work-card-fill" aria-hidden="true" />
              )}
            </div>
            <div class="work-card-info">
              <div class="work-meta">
                <span class="work-year">{entry.data.year}</span>
                <span class="work-kind">{entry.data.role}</span>
              </div>
              <h3 class="work-title">{entry.data.title}</h3>
              <p class="work-blurb">{entry.data.summary}</p>
              {entry.data.tags.length > 0 && (
                <ul class="tags" aria-label="Tags">
                  {entry.data.tags.map((t) => (
                    <li>{t}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</section>
