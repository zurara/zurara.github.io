---
import site from '../content/site.json';
---

<section class="section wrap contact" id="contact">
  <div class="reveal">
    <h2 class="contact-title">{site.contactTitle}</h2>
    <p class="contact-lede">{site.contactLede}</p>
    <a class="contact-email" href={`mailto:${site.email}`}>{site.email}</a>
    <ul class="socials" aria-label="Elsewhere">
      {
        site.socials.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener">
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
